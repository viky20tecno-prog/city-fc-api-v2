{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["routes/**", "services/**", "middleware/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "index.js"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/emails",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/cobro",
      "schedule": "0 13 * * *"
    }
  ]
}
