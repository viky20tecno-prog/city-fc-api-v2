# ============================================================
#  ZenSports API — Variables de entorno
#  Copia este archivo como .env.local y llena los valores
#  NUNCA subas el archivo con valores reales a GitHub
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://TU_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...  # Service role (admin, no expira)
SUPABASE_SECRET_KEY=              # Alias legacy — mismo valor que SERVICE_ROLE_KEY

# ── Anthropic (Claude) ────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── WAHA — WhatsApp self-hosted (Railway) ────────────────────
WAHA_URL=https://zensports-waha-production.up.railway.app
WAHA_API_KEY=                     # API key configurada en WAHA
WAHA_SESSION=default              # Nombre de la sesión activa

# ── WhatsApp Cloud API Meta (webhook) ────────────────────────
WA_ACCESS_TOKEN=                  # Token permanente de Meta
WA_PHONE_NUMBER_ID=               # Phone Number ID de Meta
WA_VERIFY_TOKEN=                  # Token de verificación del webhook
WHATSAPP_WEBHOOK_SECRET=          # Secret HMAC para validar webhooks entrantes

# ── Email — Zoho SMTP ────────────────────────────────────────
ZOHO_SMTP_USER=hola@zenpra.ai
ZOHO_SMTP_PASS=                   # Contraseña SMTP de Zoho
EMAIL_FROM=ZenSports <noreply@zenpra.ai>

# ── Seguridad interna ─────────────────────────────────────────
PDF_HMAC_SECRET=                  # HMAC para firmar URLs de PDF morosos (64 chars hex)
CRON_SECRET=                      # Header secret para rutas /api/cron/*
INTERNAL_API_SECRET=              # Header secret para /api/internal/*

# ── Servicios opcionales / legacy ────────────────────────────
# GOOGLE_SERVICE_ACCOUNT_KEY=     # JSON base64 — Google Sheets (no activo)
# GOOGLE_SHEETS_ID=               # ID hoja de cálculo (no activo)
# TWILIO_ACCOUNT_SID=             # Twilio (no activo, reemplazado por WAHA)
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=
